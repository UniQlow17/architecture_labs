# Подключение к PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cnb

# Расписание синхронизации (cron: минута час день месяц день_недели)
# По умолчанию: каждый день в 00:01
SYNC_CRON=1 0 * * *

# Список валют для синхронизации
SYNC_CURRENCIES=["EUR", "USD", "GBP", "CHF", "PLN"]

# Сколько лет истории подгружать при старте (0 = не подгружать)
SYNC_HISTORY_YEARS_BACK=3
