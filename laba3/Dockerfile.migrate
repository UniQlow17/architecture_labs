FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    alembic \
    sqlalchemy \
    psycopg2-binary \
    asyncpg \
    pydantic \
    pydantic-settings \
    httpx

COPY alembic.ini ./
COPY migrations ./migrations
COPY app ./app

ENV PYTHONPATH=/app

CMD ["alembic", "upgrade", "head"]
